{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":automergeAll"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["cargo"],
      "matchPackagePatterns": ["^oxc"],
      "groupName": "oxc crates"
    }
  ]
}
